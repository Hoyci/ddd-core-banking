{
  "info": {
    "name": "DDD Core Banking",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "client_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Onboarding",
      "item": [
        {
          "name": "Create Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const locationHeader = pm.response.headers.get('Location');",
                  "if (locationHeader) {",
                  "    const parts = locationHeader.split('/');",
                  "    pm.collectionVariables.set('client_id', parts[parts.length - 1]);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"João da Silva\",\n  \"document\": \"529.982.247-25\",\n  \"email\": \"joao.silva@example.com\",\n  \"phone\": \"11999999999\",\n  \"address\": {\n    \"zip_code\": \"01310-100\",\n    \"street\": \"Avenida Paulista\",\n    \"number\": \"1000\",\n    \"complement\": \"Apto 42\",\n    \"neighborhood\": \"Bela Vista\",\n    \"city\": \"São Paulo\",\n    \"state\": \"SP\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/clients",
              "host": ["{{base_url}}"],
              "path": ["clients"]
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Account created successfully\"\n}"
            },
            {
              "name": "409 Email Already In Use",
              "status": "Conflict",
              "code": 409,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"email already in use\"\n}"
            },
            {
              "name": "422 Validation Error",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"invalid document\"\n}"
            }
          ]
        },
        {
          "name": "Approve Client",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/clients/{{client_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["clients", "{{client_id}}", "approve"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Account approved successfully\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"client not found\"\n}"
            },
            {
              "name": "422 Not Pending",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"account is not pending\"\n}"
            }
          ]
        },
        {
          "name": "Reject Client",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Documento inválido\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/clients/{{client_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["clients", "{{client_id}}", "reject"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Account rejected successfully\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"client not found\"\n}"
            },
            {
              "name": "422 Reason Required",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"rejection reason is required\"\n}"
            }
          ]
        }
      ]
    }
  ]
}
